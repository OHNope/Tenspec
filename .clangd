CompileFlags:
    CompilationDatabase: .vscode
    Remove:
        - -freflection
        - -fmodules
        - -fmodules-ts
        - -flto
        - -fmodule-mapper=*
        - -march=*
    Add:
        - -std=c++2c
Diagnostics:
    Suppress:
        - unknown_argument
        - unsupported-option
---
If:
    PathMatch: (bindings/.*\.cpp|src/.*\.cpp|examples/.*\.cpp|tests/.*\.cpp|include/typetorch/.*\.hpp)
Diagnostics:
    Suppress: ["*"]
